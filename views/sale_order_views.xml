<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_order_form_approval" model="ir.ui.view">
        <field name="name">sale.order.form.approval</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//button[@name='action_confirm']" position="before">
                <button name="action_request_approval"
                        string="Request Approval"
                        type="object"
                        class="btn-warning"
                        invisible="not require_approval or approval_state not in ('not_required', 'rejected')"/>
                <button name="action_approve"
                        string="Approve"
                        type="object"
                        class="btn-success"
                        groups="sales_approval_workflow.group_sales_approval_manager"
                        invisible="approval_state != 'waiting'"/>
                <button name="action_reject"
                        string="Reject"
                        type="object"
                        class="btn-danger"
                        groups="sales_approval_workflow.group_sales_approval_manager"
                        invisible="approval_state != 'waiting'"/>
            </xpath>

            <xpath expr="//field[@name='state']" position="after">
                <field name="approval_state" widget="badge"
                       decoration-warning="approval_state == 'waiting'"
                       decoration-success="approval_state == 'approved'"
                       decoration-danger="approval_state == 'rejected'"/>
                <field name="require_approval" invisible="1"/>
            </xpath>

            <xpath expr="//field[@name='validity_date']" position="after">
                <field name="approved_by" readonly="1"
                       invisible="approval_state not in ('approved',)"/>
                <field name="approved_date" readonly="1"
                       invisible="approval_state not in ('approved',)"/>
                <field name="rejection_reason" readonly="1"
                       invisible="approval_state != 'rejected'"/>
            </xpath>

        </field>
    </record>

    <record id="view_sale_order_tree_approval" model="ir.ui.view">
        <field name="name">sale.order.tree.approval</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_quotation_tree_with_onboarding"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="approval_state" optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>
