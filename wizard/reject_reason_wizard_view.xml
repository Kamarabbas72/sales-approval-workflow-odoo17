<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_approval_reject_wizard_form" model="ir.ui.view">
        <field name="name">sale.approval.reject.wizard.form</field>
        <field name="model">sale.approval.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Rejection Reason">
                <group>
                    <field name="order_id" readonly="1"/>
                    <field name="reason" placeholder="Please provide a reason for rejection..."/>
                </group>
                <footer>
                    <button name="action_confirm_reject"
                            string="Confirm Rejection"
                            type="object"
                            class="btn-danger"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
